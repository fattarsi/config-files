[alias]
    # Console gitview replacement
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
    d = diff
    st = status
	s = status
    b = branch
    r = remote -v
    m = mergetool
    rbc = rebase --continue
[user]
	name = Chris Fattarsi
	email = 1092859+fattarsi@users.noreply.github.com
[giggle]
	main-window-maximized = false
	main-window-geometry = 1206x597+0+55
	history-view-vpane-position = 285
	main-window-view = HistoryView
	file-view-vpane-position = 330
[github]
	user = fattarsi
[color]
	diff = auto
[merge]
    tool = vimdiff
[diff]
	tool = vimdiff
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
