[global_config]
  focus = mouse
[keybindings]
  go_next = ""
  close_term = <Primary>w
  copy = <Primary>c
  paste = <Primary>v
  next_tab = <Shift>Right
  prev_tab = <Shift>Left
  new_window = <Primary><Shift>n
[profiles]
  [[default]]
    icon_bell = False
    background_darkness = 0.93
    background_type = transparent
    font = DejaVu Sans Mono 10
    show_titlebar = False
    scrollback_lines = 10000
    use_system_font = False
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
